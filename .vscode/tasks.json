{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "pnpm: dev",
			"type": "shell",
			"command": "pnpm",
			"args": [
				"dev",
				"--host",
				"0.0.0.0"
			],
			"isBackground": true,
			"problemMatcher": [
				{
					"owner": "astro",
					"pattern": {
						"regexp": "^",
						"file": 1,
						"location": 1,
						"message": 4
					},
					"background": {
						"activeOnStart": true,
						"beginsPattern": ".*",
						"endsPattern": ".*"
					}
				}
			],
			"group": {
				"kind": "build",
				"isDefault": true
			}
		},
		{
			"label": "pnpm: build",
			"type": "shell",
			"command": "pnpm",
			"args": [
				"build"
			],
			"group": "build"
		},
		{
			"label": "pnpm build verify",
			"type": "shell",
			"command": "pnpm",
			"args": [
				"build"
			],
			"group": "build"
		}
	]
}